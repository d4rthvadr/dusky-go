FROM golang:1.24-bookworm AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /bin/dusky-api ./cmd/api

FROM alpine:3.20

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /bin/dusky-api ./dusky-api

# Create an empty .env file to avoid "file not found" error
RUN touch /app/.env 

EXPOSE 8082

ENTRYPOINT ["./dusky-api"]